PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string, e.g. mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

JWT_SECRET=<change-me>
JWT_EXPIRES_IN=7d

# Comma-separated allowed browser origins (production). In development, localhost /
# 127.0.0.1 on any port are also allowed for easier local testing.
# Use the same host in the browser as in VITE (either all localhost or all 127.0.0.1) so
# cookies match the API URL the frontend uses (see src/apiBase.ts).
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Cookie settings
AUTH_COOKIE_NAME=govismart_auth
ADMIN_COOKIE_NAME=govismart_admin
SELLER_COOKIE_NAME=govismart_seller_auth
COOKIE_SAMESITE=lax

# Hardcoded admin login (override in production)
ADMIN_EMAIL=admin@govismart.lk
ADMIN_PASSWORD=admin123

# Python fertilizer ML service (Fertilizer_Recommandation.ipynb) — default port 5050
# ML_SERVICE_URL=http://127.0.0.1:5050
# In development the API tries to start ml_service/app.py automatically. Set to disable:
# AUTO_START_ML=0
# If "py" is not on PATH, set full path to Python:
# PYTHON_EXE=C:\Users\you\AppData\Local\Programs\Python\Python311\python.exe

