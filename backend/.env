PORT=5000
NODE_ENV=development

# MongoDB connection string (Local or Atlas)
# Using a local MongoDB default as a placeholder
MONGODB_URI=mongodb://localhost:27017/smart-fertilizer

JWT_SECRET=super-secret-key-change-me-in-production
JWT_EXPIRES_IN=7d

# Allowed browser origins
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Cookie settings
AUTH_COOKIE_NAME=govismart_auth
ADMIN_COOKIE_NAME=govismart_admin
SELLER_COOKIE_NAME=govismart_seller_auth
COOKIE_SAMESITE=lax

# Hardcoded admin login
ADMIN_EMAIL=admin@govismart.lk
ADMIN_PASSWORD=admin123

# Python fertilizer ML service
ML_SERVICE_URL=http://127.0.0.1:5050
AUTO_START_ML=1
