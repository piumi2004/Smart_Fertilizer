# Copy to `.env` or `.env.local` in this folder (Vite loads them).
# Leave VITE_API_BASE_URL unset to use same-origin `/api/...` — the Vite dev server
# proxies that to the backend (see vite.config.ts). That keeps auth cookies working.

# Only if you are NOT using the Vite proxy (e.g. static server on another port):
# VITE_API_BASE_URL=http://127.0.0.1:5000

# If the backend listens on a port other than 5000, point the dev/preview proxy at it:
# VITE_API_PROXY_TARGET=http://127.0.0.1:YOUR_PORT
